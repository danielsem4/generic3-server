###

# ============ FILE SHARE - VIEW & DELETE ============

# View specific file (get base64 content)
GET http://localhost:8000/api/v1/fileshare/1/
Content-Type: application/json

###

# Doctor: Delete file they uploaded
DELETE http://localhost:8000/api/v1/fileshare/1/
Content-Type: application/json

###

# Patient: Delete their own file
DELETE http://localhost:8000/api/v1/fileshare/2/
Content-Type: application/json

###

# Admin: Delete any file
DELETE http://localhost:8000/api/v1/fileshare/3/
Content-Type: application/json

