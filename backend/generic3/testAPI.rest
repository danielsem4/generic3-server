# ============ TWO-FACTOR AUTHENTICATION ============

# Request 2FA code via email
POST http://localhost:8000/api/v1/auth/2fa/
Content-Type: application/json

{
    "email": "ozeriyarin@gmail.com",
    "password": "a123456!",
    "send_method": "email"
}

###

# Request 2FA code via SMS
POST http://localhost:8000/api/v1/auth/2fa/
Content-Type: application/json

{
    "email": "ozeriyarin@gmail.com",
    "password": "a123456!",
    "send_method": "sms"
}

###

# Verify 2FA code for login
# IMPORTANT: After calling the 2FA request above, copy the 'sessionid' cookie from the response
# In VS Code REST Client: Look for 'Set-Cookie: sessionid=xxxxx' in the response headers
# Then paste it in the Cookie header below
POST http://localhost:8000/api/v1/auth/2fa/verify/
Content-Type: application/json
Cookie: sessionid=ospfrebrfd6yxn0vhg6h76j8ly8nrpj4

{
    "code": "938525",
    "code_type": "login"
}

###

# Verify 2FA code for signup
POST http://localhost:8000/api/v1/auth/2fa/verify/
Content-Type: application/json

{
    "code": "123456",
    "code_type": "signup"
}

###

