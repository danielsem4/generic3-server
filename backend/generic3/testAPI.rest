###

# Clinic Manager: View files for their clinic
GET http://localhost:8000/api/v1/fileshare/?clinic_id=1
Content-Type: application/json

###

# Doctor: View files for specific patient
GET http://localhost:8000/api/v1/fileshare/?clinic_id=1&patient_id=5
Content-Type: application/json

###

# Patient: View their own files (no params needed)
GET http://localhost:8000/api/v1/fileshare/
Content-Type: application/json

###

# Doctor: Upload files for a patient
POST http://localhost:8000/api/v1/fileshare/
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="clinic_id"

1
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="patient_id"

5
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="files"; filename="medical_report.pdf"
Content-Type: application/pdf

< ./path/to/medical_report.pdf
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="files"; filename="xray_image.jpg"
Content-Type: image/jpeg

< ./path/to/xray_image.jpg
------WebKitFormBoundary7MA4YWxkTrZu0gW--

###

